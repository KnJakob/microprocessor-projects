{
  "model": "opus[1m]",
  "theme": "dark-ansi",
  "hooks": {
    "UserPromptSubmit": [
      { "hooks": [
          { "type": "command",
            "command": "echo 'running' >> /tmp/claude_led_daemon" }
        ] }
    ],
    "PreToolUse": [
      { "matcher": "AskUserQuestion|ExitPlanMode",
        "hooks": [
          { "type": "command",
            "command": "echo 'attention_alert' >> /tmp/claude_led_daemon" }
        ] }
    ],
    "PermissionRequest": [
      { "hooks": [
          { "type": "command",
            "command": "echo 'attention_alert' >> /tmp/claude_led_daemon" }
        ] }
    ],
    "Notification": [
      { "matcher": "agent_needs_input",
		"hooks": [
          { "type": "command",
            "command": "echo 'attention_alert' >> /tmp/claude_led_daemon" }
        ] }
    ],
    "Elicitation": [
      { "hooks": [
          { "type": "command",
            "command": "echo 'attention_alert' >> /tmp/claude_led_daemon" }
        ] }
    ],
    "PostToolUse": [
      { "hooks": [
          { "type": "command",
            "command": "echo 'running' >> /tmp/claude_led_daemon" }
        ] }
    ],
	"PostToolUseFailure": [
      { "hooks": [
          { "type": "command",
			"command": "echo 'running' >> /tmp/claude_led_daemon" }
        ] }
    ],
	"ElicitationResult": [
      { "hooks": [
          { "type": "command",
			"command": "echo 'running' >> /tmp/claude_led_daemon" }
        ] }
    ],
    "Notification": [
      { "matcher": "agent_completed",
		"hooks": [
          { "type": "command",
            "command": "echo 'running' >> /tmp/claude_led_daemon" }
        ] }
    ],
	"PermissionDenied": [
	  { "hooks": [
		  { "type": "command",
		    "command": "echo 'waiting' >> /tmp/claude_led_daemon" }
		] }
	],
    "Stop": [
      { "hooks": [
          { "type": "command",
            "command": "echo 'waiting' >> /tmp/claude_led_daemon" }
        ] }
    ],
    "StopFailure": [
      { "hooks": [
          { "type": "command",
            "command": "echo 'waiting' >> /tmp/claude_led_daemon" }
        ] }
    ],
    "SessionEnd": [
      { "hooks": [
          { "type": "command",
            "command": "echo 'exit' >> /tmp/claude_led_daemon" }
        ] }
    ],
    "SessionStart": [
      { "hooks": [
          { "type": "command",
            "command": "echo 'waiting' >> /tmp/claude_led_daemon" }
        ] }
    ]
  }
}
