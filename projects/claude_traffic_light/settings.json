
{
  "model": "opus[1m]",
  "effortLevel": "xhigh",
  "theme": "dark-ansi",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'attention_alert' >> /tmp/claude_led_daemon"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'running' >> /tmp/claude_led_daemon"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'running_alert' >> /tmp/claude_led_daemon"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'attention' >> /tmp/claude_led_daemon"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'waiting' >> /tmp/claude_led_daemon"
          }
        ]
      }
    ]
  }
}
